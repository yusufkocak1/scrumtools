# PostgreSQL (compose icindeki "postgres" servisi; harici DB icin host/port degistirin)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=scrumtools
DB_SCHEMA=scrumtools
DB_USER=scrumtools
DB_PASSWORD=change-me-strong

MINIO_ROOT_USER=scrumtools
MINIO_ROOT_PASSWORD=change-me-strong
MINIO_BUCKET=scrumtools-attachments
# Presigned URL'lerin tarayicida acilacagi public adres
MINIO_PUBLIC_ENDPOINT=https://scrumtools.kocak.net.tr

# Frontend build-time degerleri (subdomain kokunden yayin)
VITE_API_BASE_URL=/
VITE_WS_BASE_URL=/ws
VITE_APP_BASE_PATH=/

# CORS (virgulle ayrilmis origin listesi)
APP_CORS_ALLOWED_ORIGINS=https://scrumtools.kocak.net.tr

# En az 32 karakter guclu bir deger kullanin
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRATION=86400000
