# PostgreSQL (compose icindeki "postgres" servisi; harici DB icin host/port degistirin)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=scrumtools
DB_SCHEMA=scrumtools
DB_USER=scrumtools
DB_PASSWORD=change-me-strong

MINIO_ROOT_USER=scrumtools
MINIO_ROOT_PASSWORD=change-me-strong
MINIO_BUCKET=scrumtools-attachments
# Presigned URL'lerin tarayicida acilacagi public adres
MINIO_PUBLIC_ENDPOINT=https://scrumtools.kocak.net.tr

# Frontend build-time degerleri (subdomain kokunden yayin)
VITE_API_BASE_URL=/
VITE_WS_BASE_URL=/ws
VITE_APP_BASE_PATH=/

# CORS (virgulle ayrilmis origin listesi)
APP_CORS_ALLOWED_ORIGINS=https://scrumtools.kocak.net.tr

# En az 32 karakter guclu bir deger kullanin
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRATION=86400000

# Zaman dilimi (abonelik donem hesaplari ve zamanlanmis gorevler icin sabit kalmali)
TZ=Europe/Istanbul

# E-postalardaki linklerde kullanilan frontend adresi (sifre kurulum, odeme linki vb.)
APP_FRONTEND_BASE_URL=https://scrumtools.kocak.net.tr

# ─── E-posta (SMTP) ──────────────────────────────────────────────────────────
# false iken mail gonderilmez, log'a yazilir (dev/test icin guvenli varsayilan).
# Gercek musteriye acmadan once gonderen domain'e SPF/DKIM kaydi ekleyin.
MAIL_ENABLED=false
MAIL_FROM=noreply@kocak.net.tr
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=true
SMTP_STARTTLS=true
# Lokal test icin Mailpit: SMTP_HOST=localhost SMTP_PORT=1025 SMTP_AUTH=false SMTP_STARTTLS=false

# ─── iyzico (iyzilink odeme linkleri) ────────────────────────────────────────
# false iken online odeme kapali; superadmin panelden manuel aktivasyon calisir.
IYZICO_ENABLED=false
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
# Sandbox: https://sandbox-api.iyzipay.com | Prod: https://api.iyzipay.com
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
