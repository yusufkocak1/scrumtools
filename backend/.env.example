# Shared PostgreSQL (external service)
DB_HOST=shared-postgres
DB_PORT=5432
DB_NAME=shared_db
DB_SCHEMA=scrumtools
DB_USER=scrumtools
DB_PASSWORD=change-me-strong

MINIO_ROOT_USER=scrumtools
MINIO_ROOT_PASSWORD=change-me-strong
MINIO_BUCKET=scrumtools-attachments

# Frontend /scrumtools altindan yayinlanacaksa bu degerleri kullanin
VITE_API_BASE_URL=/scrumtools/api
VITE_WS_BASE_URL=/scrumtools/ws
VITE_APP_BASE_PATH=/scrumtools/

# Sunucu IP/domain'inizi ekleyin
APP_CORS_ALLOWED_ORIGINS=http://localhost:8096

# En az 32 karakter guclu bir deger kullanin
JWT_SECRET=replace-with-long-random-secret
